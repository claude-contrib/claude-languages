{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.metadata.version"
        }
      ]
    },
    "plugins/golang": {
      "release-type": "simple",
      "component": "golang",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/.claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='golang')].version"
        }
      ]
    },
    "plugins/rust": {
      "release-type": "simple",
      "component": "rust",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/.claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='rust')].version"
        }
      ]
    },
    "plugins/terraform": {
      "release-type": "simple",
      "component": "terraform",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/.claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='terraform')].version"
        }
      ]
    }
  }
}
